                  "pm.test('Results is array', () => pm.expect(json.data).to.be.an('array'));",
                  "if (json.data.length > 0) {",
                  "  pm.test('Sorted desc by matchScore', () => {",
                  "    const scores = json.data.map(r => r.matchScore);",
                  "    for (let i = 1; i < scores.length; i++) {",
                  "      pm.expect(scores[i]).to.be.at.most(scores[i-1]);",
                  "    }",
                  "  });",
                  "}"
