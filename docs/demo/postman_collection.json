    {
      "name": "📁 AI Matching",
      "item": [
        {
          "name": "Find Best Students for Project 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Results is array', () => pm.expect(json.data).to.be.an('array'));",
                  "if (json.data.length > 0) {",
                  "  const first = json.data[0];",
                  "  pm.test('Has matchScore', () => pm.expect(first.matchScore).to.be.a('number'));",
                  "  pm.test('matchScore between 0 and 1', () => pm.expect(first.matchScore).to.be.within(0, 1));",
                  "  pm.test('entityType is STUDENT', () => pm.expect(first.entityType).to.equal('STUDENT'));",
                  "}",
                  "pm.test('Response time < 30000ms', () => pm.expect(pm.response.responseTime).to.be.below(30000));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{JOHN_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/ai-matching/find-students?projectId={{PROJECT_ID_1}}&limit=5",
              "host": ["{{BASE_URL}}"],
              "path": ["api","ai-matching","find-students"],
              "query": [{"key":"projectId","value":"{{PROJECT_ID_1}}"},{"key":"limit","value":"5"}]
